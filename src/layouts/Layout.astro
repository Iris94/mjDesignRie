---
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="sr" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Zvanični sajt RIE – Otkrij najnovija trap izdanja, biografiju i buking informacije. Digitalni asfalt, sirovo i direktno." />
    <title>RIE Music</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,700;0,800;0,900;1,700;1,900&family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-body selection:bg-accent-neon selection:text-white relative">
    <div class="grain-overlay"></div>
    <div id="splash" class="fixed inset-0 z-[9999] bg-background flex items-center justify-center transition-opacity duration-500">
      <h2 class="font-headline font-black italic text-5xl md:text-8xl text-on-surface-variant uppercase tracking-tighter opacity-0"
          style="animation: splashIn 0.8s ease-out 0.3s forwards;">ŠOUŠOUŠOU</h2>
    </div>
    <slot />
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const splash = document.getElementById('splash');
        if (!splash) return;
        setTimeout(() => {
          splash.style.opacity = '0';
          setTimeout(() => splash.remove(), 600);
        }, 2500);
      });
    </script>
  </body>
</html>
