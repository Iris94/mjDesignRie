---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Biografija from '../components/Biografija.astro';
import Izdanja from '../components/Izdanja.astro';
import Galerija from '../components/Galerija.astro';
import Merch from '../components/Merch.astro';
import MarqueeBanner from '../components/MarqueeBanner.astro';
import Buking from '../components/Buking.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main class="pt-0 md:pt-20">
    <Hero />
    <Biografija />
    <Izdanja />
    <Galerija />
    <MarqueeBanner items={['Trap', 'Drill', 'Afrobeat', 'Alt R&B', 'Rap']} />
    <Merch />
    <Buking />
  </main>
  <Footer />
</Layout>
