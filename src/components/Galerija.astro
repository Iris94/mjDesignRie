---
import TexturedBackground from './TexturedBackground.astro';

const images = [
  '/IMG_4468.PNG', '/IMG_4469.PNG', '/IMG_4470.PNG',
  '/IMG_4471.PNG', '/IMG_4472.PNG', '/IMG_4473.PNG',
  '/IMG_4474.PNG', '/IMG_4475.PNG', '/IMG_4476.PNG',
  '/IMG_4477.PNG',
  '/IMG_4529.PNG', '/IMG_4530.PNG',
];
---

<section class="relative py-24 bg-background border-b border-surface-variant overflow-hidden" id="galerija">
  <TexturedBackground />
  <div class="px-4 md:px-grid-margin relative z-10">
    <div class="columns-2 md:columns-3 lg:columns-4 gap-4">
      {images.map((src) => (
        <div class="break-inside-avoid mb-4 overflow-hidden group">
          <img src={src} alt="" loading="lazy" class="w-full h-auto transition-transform duration-500 group-hover:scale-105" />
        </div>
      ))}
    </div>
  </div>
</section>
