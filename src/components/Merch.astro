---
import Headline from './Headline.astro';
---

<section class="py-24 bg-surface border-b border-surface-variant" id="merch">
  <Headline title="MERCH" class="pb-xl" />
  <div class="px-4 md:px-grid-margin py-12 flex flex-col items-center justify-center text-center">
    <div class="relative group cursor-default">
      <h3 class="font-headline text-5xl md:text-8xl font-black italic uppercase tracking-tighter text-surface-variant group-hover:text-primary transition-colors duration-500">DOSTUPNO USKORO</h3>
      <div class="absolute -inset-4 border border-surface-variant opacity-20 pointer-events-none"></div>
    </div>
    <p class="mt-8 font-label text-on-surface-variant tracking-[0.2em] uppercase text-sm">Pratite nas za prve dropove</p>
  </div>
</section>
