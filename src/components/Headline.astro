---
interface Props {
  title: string;
  as?: 'h1' | 'h2';
  class?: string;
}

const { title, as: Tag = 'h2', class: wrapperClass = '' } = Astro.props;
---

<div class="px-4 md:px-grid-margin {wrapperClass}">
  <Tag class="font-headline text-5xl md:text-[80px] italic font-black text-on-surface uppercase leading-none tracking-tighter">
    {title}
  </Tag>
  <div class="w-24 h-2 bg-accent-neon mt-sm"></div>
</div>
